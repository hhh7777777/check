# WeChat Cloud Run Backend Service - Environment Variables
# Copy this file to .env and fill in the values

# WeChat App Configuration
WX_APPID=your-wechat-app-id
WX_APPSECRET=your-wechat-app-secret

# WeChat Cloud Development Environment ID
WX_ENV_ID=your-cloudbase-env-id

# JWT Secret for admin authentication
JWT_SECRET=replace-with-at-least-32-random-characters

# Comma-separated allowed admin origins. Leave empty only during local development.
CORS_ORIGINS=http://localhost:5173

# Server Port (Cloud Run default is 80)
PORT=80
