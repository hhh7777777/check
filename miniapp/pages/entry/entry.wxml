<view class="page">
  <view class="bg-decor">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
    <view class="bg-streak bg-streak-1"></view>
    <view class="bg-streak bg-streak-2"></view>
  </view>

  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="content">
    <view class="title-main">新加坡国立大学广州研究院</view>

    <view class="query-area">
      <view class="query-label">请输入手机号查询参会信息</view>

      <view class="input-wrapper">
        <input
          class="phone-input"
          type="text"
          maxlength="24"
          placeholder="国内手机号或 +国家区号国际手机号"
          placeholder-style="color: #94A3B8;"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="query-btn {{queryReady ? 'active' : ''}}" bindtap="onQuery">
        <text>立即查询</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="footer-line"></view>
    <view class="footer-text">
      <text>本活动仅面向受邀参会人员提供信息查询服务</text>
    </view>
    <view class="footer-text">
      <text class="footer-link" bindtap="showPrivacy">《用户隐私协议》</text>
    </view>
    <view class="footer-line"></view>
  </view>
</view>
