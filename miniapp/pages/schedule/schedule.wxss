/* ========== 会议日程页 - 深蓝色科幻主题 ========== */

.sub-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  position: relative;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.nav-back {
  position: absolute;
  left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.loading,
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

/* 日期分组 */
.date-group {
  margin-bottom: 32rpx;
}

.date-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  background: rgba(58, 138, 238, 0.2);
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(58, 138, 238, 0.3);
}

/* 时间轴 */
.timeline-item {
  display: flex;
  margin-bottom: 8rpx;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
  padding-top: 24rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #3a8aee;
  flex-shrink: 0;
  box-shadow: 0 0 12rpx rgba(58, 138, 238, 0.5);
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  margin-top: 8rpx;
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-content {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-left: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.time-range {
  font-size: 24rpx;
  color: #f59e0b;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.schedule-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.schedule-info {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.info-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.schedule-remark {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  line-height: 1.6;
}

/* 并发议程 */
.timeline-item-concurrent {
  align-items: flex-start;
}

.concurrent-dot {
  background: #f59e0b;
  box-shadow: 0 0 12rpx rgba(245, 158, 11, 0.5);
}

.concurrent-group {
  flex: 1;
  margin-left: 16rpx;
  margin-bottom: 16rpx;
}

.concurrent-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.concurrent-time {
  font-size: 24rpx;
  color: #f59e0b;
  font-weight: 500;
}

.concurrent-badge {
  font-size: 20rpx;
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.concurrent-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.concurrent-card {
  background: rgba(245, 158, 11, 0.08);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
  margin-bottom: 0;
}

/* 返回首页按钮 */
.back-home {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 60rpx;
}

.back-home-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(58, 138, 238, 0.4);
}

.back-home-btn::after {
  border: none;
}

.back-home-btn:active {
  opacity: 0.8;
}
