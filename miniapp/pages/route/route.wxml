<view class="sub-page">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <view class="nav-back-icon"></view>
    </view>
    <text class="nav-title">会议手册</text>
  </view>

  <!-- PDF直接展示 -->
  <view class="pdf-container" wx:if="{{hasPdf && pdfUrl}}">
    <web-view src="{{pdfUrl}}" binderror="onWebViewError" class="pdf-webview"></web-view>
  </view>

  <!-- web-view失败时的回退 -->
  <view class="content-card" wx:if="{{webViewError}}">
    <view class="section-title">
      <text>会议手册</text>
    </view>
    <view class="pdf-btn" bindtap="openPdf">
      <view class="pdf-icon">PDF</view>
      <view class="pdf-info">
        <text class="pdf-label">点击查看会议手册</text>
        <text class="pdf-desc">点击后在新窗口打开PDF</text>
      </view>
      <text class="pdf-arrow">›</text>
    </view>
  </view>

  <!-- 无数据提示 -->
  <view class="empty-tip" wx:if="{{!hasPdf && loaded}}">
    <text>暂无会议手册</text>
  </view>

  <!-- 底部返回首页按钮 -->
  <view class="back-home">
    <view class="back-home-btn" bindtap="goHome">返回首页</view>
  </view>
</view>
