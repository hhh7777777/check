/* ========== 参会路线页 - 深蓝色科幻主题 ========== */

.sub-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  position: relative;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.nav-back {
  position: absolute;
  left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 内容卡片 */
.content-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3a8aee;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 地址行 */
.address-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.address-icon {
  position: relative;
  width: 40rpx;
  height: 60rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.pin {
  width: 32rpx;
  height: 32rpx;
  background: #3a8aee;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  position: absolute;
  top: 0;
  left: 4rpx;
}

.pin-shadow {
  width: 20rpx;
  height: 8rpx;
  background: rgba(58, 138, 238, 0.3);
  border-radius: 50%;
  position: absolute;
  bottom: 0;
  left: 10rpx;
}

.address-info {
  flex: 1;
}

.address-text {
  font-size: 30rpx;
  color: #ffffff;
  line-height: 1.6;
}

/* 导航按钮 */
.nav-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 40rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(58, 138, 238, 0.4);
}

.nav-btn::after {
  border: none;
}

.nav-btn:active {
  opacity: 0.8;
}

.transport-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  white-space: pre-wrap;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

/* 温馨提示 */
.tip-title {
  color: #f59e0b;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
  padding-left: 24rpx;
  position: relative;
}

.tip-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  background: #f59e0b;
  border-radius: 50%;
}

/* 返回首页按钮 */
.back-home {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 60rpx;
}

.back-home-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(58, 138, 238, 0.4);
}

.back-home-btn::after {
  border: none;
}

.back-home-btn:active {
  opacity: 0.8;
}
