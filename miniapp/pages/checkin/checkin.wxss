.sub-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  position: relative;
  height: 88rpx;
}

.nav-back {
  position: absolute;
  left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid rgba(255,255,255,0.8);
  border-bottom: 4rpx solid rgba(255,255,255,0.8);
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 内容卡片 */
.content-card {
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

/* 操作员输入 */
.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.dark-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 0 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
  margin-top: 24rpx;
}

.search-btn::after {
  border: none;
}

.search-btn:active {
  opacity: 0.8;
}

/* 操作员信息栏 */
.operator-bar {
  background: rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.operator-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
}

.operator-name {
  font-size: 28rpx;
  color: #3a8aee;
  font-weight: bold;
}

/* 扫码卡片 */
.scan-card {
  text-align: center;
  padding: 60rpx 32rpx;
}

.scan-icon-wrap {
  margin-bottom: 24rpx;
}

.scan-icon {
  font-size: 80rpx;
}

.scan-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 8rpx;
}

.scan-tip {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  margin-bottom: 32rpx;
}

/* 结果卡片 */
.result-card {
  text-align: center;
  border-top: 8rpx solid transparent;
}

.success-card {
  border-top-color: #67C23A;
}

.warning-card {
  border-top-color: #E6A23C;
}

.error-card {
  border-top-color: #F56C6C;
}

.result-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.success-icon {
  background: #67C23A;
}

.warning-icon {
  background: #E6A23C;
}

.error-icon {
  background: #F56C6C;
}

.result-status {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.success-text {
  color: #67C23A;
}

.warning-text {
  color: #E6A23C;
}

.error-text {
  color: #F56C6C;
}

.result-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.4);
  margin-bottom: 24rpx;
}

.result-info {
  text-align: left;
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

.info-value {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
}

/* 返回首页按钮 */
.back-home {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 60rpx;
}

.back-home-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(42,90,174,0.4);
}

.back-home-btn::after {
  border: none;
}

.back-home-btn:active {
  opacity: 0.8;
}

/* 手动输入分隔线 */
.manual-divider {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255,255,255,0.15);
}

.divider-text {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}
