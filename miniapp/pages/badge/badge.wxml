<view class="sub-page">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <view class="nav-back-icon"></view>
    </view>
    <text class="nav-title">电子参会证</text>
  </view>

  <!-- 电子参会证 -->
  <view class="badge-card" wx:if="{{attendee}}">
    <!-- 头部 -->
    <view class="badge-header">
      <view class="badge-header-title">电子参会证</view>
    </view>

    <!-- 信息区域 -->
    <view class="badge-body">
      <view class="badge-field">
        <text class="field-label">姓名</text>
        <text class="field-value">{{attendee.name}}</text>
      </view>
      <view class="badge-field">
        <text class="field-label">单位</text>
        <text class="field-value">{{attendee.organization}}</text>
      </view>
      <view class="badge-field">
        <text class="field-label">身份类型</text>
        <text class="field-value">{{attendee.identityType}}</text>
      </view>
      <view class="badge-field">
        <text class="field-label">参会码</text>
        <text class="field-value code-value">{{attendee.attendeeCode}}</text>
      </view>
      <view class="badge-field" wx:if="{{attendee.diningPlace}}">
        <text class="field-label">用餐地点</text>
        <text class="field-value">{{attendee.diningPlace}}</text>
      </view>
      <view class="badge-field" wx:if="{{attendee.seatNo}}">
        <text class="field-label">座位号</text>
        <text class="field-value">{{attendee.seatNo}}</text>
      </view>
      <view class="badge-field" wx:if="{{attendee.tableNo}}">
        <text class="field-label">餐桌号</text>
        <text class="field-value">{{attendee.tableNo}}</text>
      </view>
      <view class="badge-field" wx:if="{{attendee.hotelName}}">
        <text class="field-label">酒店名称</text>
        <text class="field-value">{{attendee.hotelName}}</text>
      </view>
      <view class="badge-field" wx:if="{{attendee.roomNo}}">
        <text class="field-label">房间号</text>
        <text class="field-value">{{attendee.roomNo}}</text>
      </view>
      <view class="badge-field" wx:if="{{attendee.qrContent}}">
        <text class="field-label">凭证码</text>
        <text class="field-value code-value">{{attendee.qrContent}}</text>
      </view>
    </view>

    <view class="re-query-btn" bindtap="previewQr">查看凭证码</view>
    <view class="re-query-btn secondary" bindtap="reQuery">重新查询</view>
  </view>

  <!-- 底部返回首页按钮 -->
  <view class="back-home">
    <view class="back-home-btn" bindtap="goHome">返回首页</view>
  </view>
</view>
