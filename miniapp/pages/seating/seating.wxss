/* ========== 座位/酒店页 - 深蓝色科幻主题 ========== */

.sub-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  position: relative;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.nav-back {
  position: absolute;
  left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 内容卡片 */
.content-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 查询表单 */
.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.dark-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
  margin-top: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(58, 138, 238, 0.4);
}

.search-btn::after {
  border: none;
}

.search-btn:active {
  opacity: 0.8;
}

/* 错误提示 */
.error-card {
  text-align: center;
}

.error-text {
  color: #f87171;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

/* 查询结果 */
.result-header {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  text-align: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.group-divider {
  font-size: 26rpx;
  color: #3a8aee;
  font-weight: bold;
  margin-top: 24rpx;
  margin-bottom: 16rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx dashed rgba(58, 138, 238, 0.3);
}

.result-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.field-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
}

.field-value {
  font-size: 28rpx;
  color: #ffffff;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
}

.field-value.highlight {
  font-weight: bold;
  color: #3a8aee;
  font-size: 32rpx;
}

/* 重新查询 */
.re-query-btn {
  margin-top: 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border: 2rpx solid #3a8aee;
  color: #3a8aee;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.re-query-btn:active {
  background: rgba(58, 138, 238, 0.1);
}

/* 返回首页按钮 */
.back-home {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 60rpx;
}

.back-home-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(58, 138, 238, 0.4);
}

.back-home-btn::after {
  border: none;
}

.back-home-btn:active {
  opacity: 0.8;
}
