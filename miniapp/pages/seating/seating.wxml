<view class="sub-page">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <view class="nav-back-icon"></view>
    </view>
    <text class="nav-title">座位餐序酒店</text>
  </view>

  <!-- 查询结果 -->
  <view class="content-card result-card" wx:if="{{attendee}}">
    <view class="result-header">查询结果</view>

    <view class="result-field">
      <text class="field-label">姓名</text>
      <text class="field-value">{{attendee.name}}</text>
    </view>
    <view class="result-field">
      <text class="field-label">单位</text>
      <text class="field-value">{{attendee.organization}}</text>
    </view>
    <view class="result-field">
      <text class="field-label">身份类型</text>
      <text class="field-value">{{attendee.identityType}}</text>
    </view>

    <!-- 座位信息 -->
    <view class="group-divider">座位信息</view>
    <view class="result-field" wx:if="{{attendee.seatNo}}">
      <text class="field-label">座位号</text>
      <text class="field-value highlight">{{attendee.seatNo}}</text>
    </view>

    <!-- 餐序信息 -->
    <view class="group-divider">餐序信息</view>
    <view class="result-field" wx:if="{{attendee.tableNo}}">
      <text class="field-label">餐桌号</text>
      <text class="field-value highlight">{{attendee.tableNo}}</text>
    </view>
    <view class="result-field" wx:if="{{attendee.diningPlace}}">
      <text class="field-label">用餐地点</text>
      <text class="field-value">{{attendee.diningPlace}}</text>
    </view>

    <!-- 酒店信息 -->
    <view class="group-divider">酒店信息</view>
    <view class="result-field" wx:if="{{attendee.hotelName}}">
      <text class="field-label">酒店名称</text>
      <text class="field-value">{{attendee.hotelName}}</text>
    </view>
    <view class="result-field" wx:if="{{attendee.roomNo}}">
      <text class="field-label">房间号</text>
      <text class="field-value highlight">{{attendee.roomNo}}</text>
    </view>

    <!-- 备注 -->
    <view class="result-field" wx:if="{{attendee.remark}}">
      <text class="field-label">备注</text>
      <text class="field-value">{{attendee.remark}}</text>
    </view>

    <!-- 重新查询 -->
    <view class="re-query-btn" bindtap="reQuery">重新查询</view>
  </view>

  <!-- 底部返回首页按钮 -->
  <view class="back-home">
    <view class="back-home-btn" bindtap="goHome">返回首页</view>
  </view>
</view>
