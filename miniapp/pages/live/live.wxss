/* ========== 图文直播页 ========== */
.sub-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.status-bar { width: 100%; }

.nav-bar {
  display: flex; align-items: center; justify-content: center;
  padding: 16rpx 24rpx; position: relative; height: 88rpx;
  background: rgba(255,255,255,0.05); border-bottom: 1rpx solid rgba(255,255,255,0.1);
}
.nav-back {
  position: absolute; left: 20rpx; width: 64rpx; height: 64rpx;
  border-radius: 50%; background: rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
}
.nav-back-icon {
  width: 20rpx; height: 20rpx;
  border-left: 4rpx solid #fff; border-bottom: 4rpx solid #fff;
  transform: rotate(45deg); margin-left: 8rpx;
}
.nav-title { font-size: 34rpx; font-weight: 600; color: #fff; }

/* 二维码卡片 */
.qr-card {
  margin-top: 32rpx; padding: 40rpx 24rpx;
  background: rgba(255,255,255,0.06); border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.08); text-align: center;
}
.qr-header { display: flex; align-items: center; justify-content: center; gap: 10rpx; margin-bottom: 24rpx; }
.qr-header-text { font-size: 24rpx; font-weight: 700; color: #ef4444; letter-spacing: 4rpx; }
.qr-title { font-size: 32rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.qr-desc { font-size: 24rpx; color: rgba(255,255,255,0.4); margin-bottom: 32rpx; }
.qr-wrapper {
  width: 400rpx; height: 400rpx; margin: 0 auto;
  background: #fff; border-radius: 16rpx; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.qr-canvas { width: 200px !important; height: 200px !important; }
.qr-url { margin-top: 16rpx; font-size: 20rpx; color: rgba(255,255,255,0.25); word-break: break-all; }

/* 最新图片 */
.latest-card {
  margin-top: 24rpx; padding: 24rpx;
  background: rgba(255,255,255,0.06); border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.latest-label { font-size: 24rpx; color: rgba(255,255,255,0.4); margin-bottom: 16rpx; letter-spacing: 2rpx; }
.latest-image { width: 100%; border-radius: 12rpx; }

/* 底部按钮 */
.back-home { display: flex; justify-content: center; padding: 48rpx 0 60rpx; }
.back-home-btn {
  width: 80%; height: 88rpx; line-height: 88rpx; text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #fff; border-radius: 44rpx; font-size: 32rpx; border: none;
  box-shadow: 0 8rpx 24rpx rgba(58,138,238,0.4);
}
.back-home-btn::after { border: none; }
.back-home-btn:active { opacity: 0.8; }
