/* ========== 会议介绍页 - 深蓝色科幻主题 ========== */

.sub-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  position: relative;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.nav-back {
  position: absolute;
  left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 内容卡片 */
.content-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 标题卡片 */
.title-card {
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(58, 138, 238, 0.3);
  text-align: center;
  padding: 40rpx 32rpx;
}

.org-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.6;
}

.title-card .card-title {
  color: #ffffff;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3a8aee;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.info-value {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.6;
}

.description-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  text-align: justify;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

/* 返回首页按钮 */
.back-home {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 60rpx;
}

.back-home-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(58, 138, 238, 0.4);
}

.back-home-btn::after {
  border: none;
}

.back-home-btn:active {
  opacity: 0.8;
}
