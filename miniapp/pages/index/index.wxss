/* ========== 首页 - 深蓝色科幻主题 ========== */

/* 页面容器 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  position: relative;
  overflow: hidden;
}

/* ========== 背景装饰 - 蓝色圆圈 ========== */
.bg-decor {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: rgba(58, 138, 238, 0.15);
  top: -100rpx;
  right: -100rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: rgba(58, 138, 238, 0.1);
  top: 300rpx;
  left: -80rpx;
}

.bg-circle-3 {
  width: 250rpx;
  height: 250rpx;
  background: rgba(58, 138, 238, 0.08);
  bottom: 200rpx;
  right: -60rpx;
}

.bg-streak {
  position: absolute;
  width: 300rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 138, 238, 0.2), transparent);
  transform: rotate(-30deg);
}

.bg-streak-1 {
  top: 120rpx;
  right: 40rpx;
}

.bg-streak-2 {
  top: 180rpx;
  right: 80rpx;
  width: 200rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 138, 238, 0.15), transparent);
}

/* ========== 状态栏 ========== */
.status-bar {
  width: 100%;
}

/* ========== 标题区域 ========== */
.header {
  padding: 20rpx 40rpx 32rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.5;
  letter-spacing: 2rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #f59e0b;
  margin-top: 8rpx;
  line-height: 1.4;
}

/* ========== 卡片区域 ========== */
.card-area {
  padding: 0 28rpx;
  position: relative;
  z-index: 1;
}

/* 通用卡片样式 - 半透明背景 */
.card {
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  transition: transform 0.2s;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.card:active {
  transform: scale(0.98);
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.card-subtitle {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1rpx;
  line-height: 1.6;
  font-weight: 500;
}

/* ========== 会议介绍 - 全宽大卡片 ========== */
.card-intro {
  width: 100%;
  height: 260rpx;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(58, 138, 238, 0.3);
  border: none;
}

.card-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding: 36rpx;
  position: relative;
}

.card-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, transparent 50%);
  pointer-events: none;
}

.card-text {
  position: relative;
  z-index: 1;
  flex: 1;
}

.card-intro .card-title {
  color: #ffffff;
}

.card-intro .card-subtitle {
  color: rgba(255, 255, 255, 0.7);
}

.card-btn {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.1);
}

.btn-text {
  font-size: 22rpx;
  color: #ffffff;
  margin-right: 8rpx;
}

.btn-arrow {
  font-size: 24rpx;
  color: #ffffff;
}

/* 会议介绍图标 - 柱状图 */
.card-icon-area {
  width: 200rpx;
  height: 180rpx;
  position: relative;
  flex-shrink: 0;
}

.icon-chart {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  height: 140rpx;
  padding-top: 40rpx;
  justify-content: center;
}

.chart-bar {
  width: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.4));
  border-radius: 6rpx 6rpx 0 0;
}

.icon-cylinder {
  position: absolute;
  bottom: 0;
  right: 10rpx;
}

.cylinder-ring {
  width: 50rpx;
  height: 14rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  margin-top: -6rpx;
  background: rgba(255, 255, 255, 0.15);
}

/* ========== 两列网格布局 ========== */
.card-grid {
  display: flex;
  gap: 20rpx;
}

.card-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-col-left {
  flex: 1.15;
}

.card-col-right {
  flex: 0.85;
}

/* ========== 会议日程卡片 ========== */
.card-schedule {
  flex: 1;
  min-height: 300rpx;
  background: linear-gradient(135deg, #d97706, #f59e0b);
  box-shadow: 0 8rpx 32rpx rgba(245, 158, 11, 0.3);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 30rpx;
  border: none;
}

.card-schedule .card-title {
  color: #ffffff;
}

.card-schedule .card-subtitle {
  color: rgba(255, 255, 255, 0.7);
}

/* 放大镜图标 */
.icon-magnifier {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-left: auto;
  margin-top: 20rpx;
}

.mag-glass {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 10rpx;
  background: rgba(255, 255, 255, 0.1);
}

.mag-handle {
  width: 8rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.6);
  position: absolute;
  bottom: 0;
  right: 15rpx;
  transform: rotate(45deg);
  border-radius: 4rpx;
}

/* ========== 电子参会证卡片 ========== */
.card-badge {
  background: linear-gradient(135deg, #1e3a8a, #2563eb);
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 200rpx;
  border: none;
}

.card-badge .card-title {
  color: #ffffff;
}

.card-badge .card-subtitle {
  color: rgba(255, 255, 255, 0.7);
}

/* 人物图标 */
.icon-person {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-left: auto;
  margin-top: 16rpx;
}

.person-head {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  margin: 0 auto 8rpx;
}

.person-body {
  width: 56rpx;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 28rpx 28rpx 0 0;
  margin: 0 auto;
}

/* ========== 座位/酒店卡片 ========== */
.card-seating {
  background: linear-gradient(135deg, #0369a1, #0ea5e9);
  box-shadow: 0 8rpx 32rpx rgba(14, 165, 233, 0.3);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 200rpx;
  border: none;
}

.card-seating .card-title {
  color: #ffffff;
}

.card-seating .card-subtitle {
  color: rgba(255, 255, 255, 0.7);
}

/* 建筑图标 */
.icon-building {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  margin-left: auto;
  margin-top: 16rpx;
}

.building-floor {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 4rpx;
}

.building-floor:nth-child(1) { width: 40rpx; }
.building-floor:nth-child(2) { width: 56rpx; }
.building-floor:nth-child(3) { width: 48rpx; }

/* ========== 参会路线卡片 ========== */
.card-route {
  background: linear-gradient(135deg, #047857, #10b981);
  box-shadow: 0 8rpx 32rpx rgba(16, 185, 129, 0.3);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 200rpx;
  border: none;
}

.card-route .card-title {
  color: #ffffff;
}

.card-route .card-subtitle {
  color: rgba(255, 255, 255, 0.7);
}

/* 地图图标 */
.icon-map {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-left: auto;
  margin-top: 16rpx;
}

.map-pin {
  width: 24rpx;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  position: absolute;
  top: 10rpx;
  left: 28rpx;
}

.map-circle {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  position: absolute;
  bottom: 0;
  left: 10rpx;
}

/* ========== 图文直播卡片 ========== */
.card-live {
  background: linear-gradient(135deg, #0e8a8a, #14b5b5);
  box-shadow: 0 8rpx 32rpx rgba(20, 181, 181, 0.3);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 200rpx;
  border: none;
}

.card-live .card-title {
  color: #ffffff;
}

.card-live .card-subtitle {
  color: rgba(255, 255, 255, 0.7);
}

/* 相机图标 */
.icon-camera {
  position: relative;
  width: 80rpx;
  height: 60rpx;
  margin-left: auto;
  margin-top: 16rpx;
}

.cam-body {
  width: 70rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 8rpx;
  position: absolute;
  bottom: 0;
  left: 5rpx;
}

.cam-lens {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  position: absolute;
  top: 8rpx;
  left: 25rpx;
}

/* 签到卡片 */
.card-checkin {
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  box-shadow: 0 8rpx 32rpx rgba(58, 138, 238, 0.3);
  padding: 28rpx 32rpx;
  margin-top: 8rpx;
  border: none;
}

.card-checkin .card-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-checkin .card-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.card-checkin .card-subtitle {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.card-checkin .card-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.card-checkin .btn-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.card-checkin .btn-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 勾选图标 */
.icon-check {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.check-mark {
  width: 36rpx;
  height: 20rpx;
  border-left: 5rpx solid #ffffff;
  border-bottom: 5rpx solid #ffffff;
  transform: rotate(-45deg);
  margin-top: -6rpx;
}

/* ========== 底部 ========== */
.footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 40rpx 60rpx;
  gap: 20rpx;
}

.footer-line {
  width: 80rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.2);
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  white-space: nowrap;
}
