/* ========== 全局样式 - 深蓝色科幻主题 ========== */

/* 页面基础样式 */
page {
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  box-sizing: border-box;
}

/* 通用半透明卡片 */
.dark-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 通用半透明卡片（用于子页面内容） */
.light-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 导航栏 - 深蓝色主题 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  position: relative;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  position: absolute;
  left: 20rpx;
  z-index: 10;
}

.nav-back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.nav-title {
  width: 100%;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 返回首页按钮 */
.back-home {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 60rpx;
}

.back-home-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(58, 138, 238, 0.4);
}

.back-home-btn::after {
  border: none;
}

/* 页面子页面背景 */
.sub-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #0d1f3c 50%, #122a4a 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

/* 子页面内容卡片 */
.content-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 内容标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3a8aee;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #3a8aee;
}

/* 内容文本 */
.section-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
}

/* 表单输入框 */
.dark-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 搜索按钮 */
.search-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #2a5aae, #3a8aee);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(58, 138, 238, 0.4);
  margin-top: 24rpx;
}

.search-btn::after {
  border: none;
}

/* 加载状态 */
.loading-text {
  text-align: center;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  padding: 40rpx 0;
}

/* 空状态 */
.empty-text {
  text-align: center;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
  padding: 60rpx 0;
}
